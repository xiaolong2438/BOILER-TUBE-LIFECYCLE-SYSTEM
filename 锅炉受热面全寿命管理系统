</nav>

<main>
  <!-- 1. DASHBOARD -->
  <section class="view active" id="view-dashboard">
    <div class="section-title"><h2>系统总览</h2><span class="sub">OVERVIEW · 宝钢湛江 #1机组</span></div>
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-label">单炉管理单元</div><div class="stat-value" data-count="5139">0</div></div>
      <div class="stat-card"><div class="stat-label">水冷壁管 (WW)</div><div class="stat-value" data-count="722">0</div></div>
      <div class="stat-card"><div class="stat-label">过热器系统 (SH)</div><div class="stat-value" data-count="2681">0</div></div>
      <div class="stat-card"><div class="stat-label">再热+省煤器</div><div class="stat-value" data-count="1736">0</div></div>
    </div>
    <div class="grid-2">
      <div class="card">
        <div class="card-title">部件健康度评估</div>
        <div class="progress-row"><div class="progress-label"><span>水冷壁 · WW</span><span>87%</span></div><div class="progress-bar"><div class="progress-fill ok" style="width:87%"></div></div></div>
        <div class="progress-row"><div class="progress-label"><span>低温过热器 · LSH</span><span>72%</span></div><div class="progress-bar"><div class="progress-fill" style="width:72%"></div></div></div>
        <div class="progress-row"><div class="progress-label"><span>高温过热器 · HSH</span><span>42%</span></div><div class="progress-bar"><div class="progress-fill warn" style="width:42%"></div></div></div>
        <div class="progress-row"><div class="progress-label"><span>高温再热器 · HRH</span><span>38%</span></div><div class="progress-bar"><div class="progress-fill danger" style="width:38%"></div></div></div>
      </div>
      <div class="card">
