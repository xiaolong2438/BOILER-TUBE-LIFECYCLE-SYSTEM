function matchComponentFromCode(code) { const parts = code.split('-'); if(parts.length < 3) return null; const sys = parts[1]; const zone = parts[2]; return matrix.find(m => m.sys === sys && m.zone === zone) || matrix.find(m => m.sys === sys); }

function doSearch() { const q = document.getElementById('searchInput').value.trim().toUpperCase(); const res = document.getElementById('searchResult'); if(!q) { res.innerHTML = '<div class="alert alert-info">请输入管码关键词</div>'; return; } let matches = []; let matchedCodes = new Set(); userDB.events.forEach(e => { if(e.code.includes(q) && !matchedCodes.has(e.code)) { const eventsForCode = userDB.events.filter(ev => ev.code === e.code).sort((a,b) => new Date(a.date) - new Date(b.date)); let compInfo = matchComponentFromCode(e.code); matches.push({ code: e.code, data: { name: compInfo ? compInfo.name : '动态管段', spec: compInfo ? compInfo.spec : '--', install: eventsForCode[0].date, risk: `共 ${eventsForCode.length} 条记录` }, source: 'local' }); matchedCodes.add(e.code); } }); if(matches.length === 0) { res.innerHTML = `<div class="alert alert-warn">未找到匹配记录</div>`; return; } res.innerHTML = matches.map(m => `<div class="tube-detail"><h3>${m.code} <span class="badge badge-ww" style="margin-left:10px;">本地数据</span></h3><div class="info-grid"><div class="info-item"><div class="k">部件</div><div class="v">${m.data.name}</div></div><div class="info-item"><div class="k">规格</div><div class="v">${m.data.spec}</div></div></div><button class="btn" style="margin-top:15px;" onclick="jumpLifecycle('${m.code}')">查看寿命时间线 →</button></div>`).join(''); }
function jumpLifecycle(code) { document.querySelector('[data-view="lifecycle"]').click(); loadLifecycle(code); }

document.querySelectorAll('.comp-tab').forEach(tab => { tab.addEventListener('click', () => { document.querySelectorAll('.comp-tab').forEach(t => t.classList.remove('active')); tab.classList.add('active'); renderComponent(tab.dataset.comp); }); });
function renderComponent(key) { const c = COMPONENTS[key]; document.getElementById('compContent').innerHTML = `<div class="card"><div class="card-title"><span class="badge ${c.badge}">${c.sys}</span> ${c.name}</div><div class="info-grid"><div class="info-item"><div class="k">规格</div><div class="v">${c.spec}</div></div><div class="info-item"><div class="k">材质</div><div class="v">${c.mat}</div></div><div class="info-item"><div class="k">数量</div><div class="v">${c.count}</div></div></div></div>`; }
