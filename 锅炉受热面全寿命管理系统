function updateLifecycleDropdown() { const sel = document.getElementById('lcSelect'); const codes = [...new Set(userDB.events.map(e => e.code))]; sel.innerHTML = '<option value="">-- 请选择管码 --</option>' + codes.map(c => `<option value="${c}">${c}</option>`).join(''); }
function loadLifecycle(customCode) { const code = customCode || document.getElementById('lcSelect').value || document.getElementById('lcCustomCode').value.trim().toUpperCase(); if(!code) return; const localEvents = userDB.events.filter(e => e.code === code).sort((a,b) => new Date(a.date) - new Date(b.date)); if(localEvents.length === 0) { document.getElementById('lcContent').innerHTML = `<div class="alert alert-warn">未找到 ${code} 的任何数据。</div>`; return; } let compInfo = matchComponentFromCode(code); const thicknessData = extractThicknessData(code); let miniChartSVG = ''; if (thicknessData.length >= 2) { const w = 400, h = 100, p = 20; const minY = Math.min(...thicknessData.map(d=>d.val)) * 0.95; const maxY = Math.max(...thicknessData.map(d=>d.val)) * 1.05; const minX = thicknessData[0].year; const maxX = thicknessData[thicknessData.length-1].year; const xS = x => p + ((x-minX)/(maxX-minX || 1)) * (w-2*p); const yS = y => h - p - ((y-minY)/(maxY-minY || 1)) * (h-2*p); let path = thicknessData.map((d,i) => `${i===0?'M':'L'} ${xS(d.year)} ${yS(d.val)}`).join(' '); miniChartSVG = `<svg class="mini-chart" viewBox="0 0 ${w} ${h}"><path d="${path}" fill="none" stroke="#00d4ff" stroke-width="2"/><path d="${path} L ${xS(maxX)} ${h-p} L ${xS(minX)} ${h-p} Z" fill="rgba(0,212,255,0.1)"/>${thicknessData.map(d=>`<circle cx="${xS(d.year)}" cy="${yS(d.val)}" r="3" fill="#00d4ff"/>`).join('')}</svg>`; } document.getElementById('lcContent').innerHTML = `<div class="card"><div class="card-title">管段基本信息</div><h2 style="font-family:'Consolas',monospace; color:var(--accent); letter-spacing:3px; margin-bottom:18px;">${code}</h2><div class="info-grid"><div class="info-item"><div class="k">部件</div><div class="v">${compInfo?compInfo.name:'未知'}</div></div><div class="info-item"><div class="k">规格材质</div><div class="v">${compInfo?compInfo.spec+' · '+compInfo.mat:'--'}</div></div><div class="info-item"><div class="k">有效测厚点</div><div class="v">${thicknessData.length} 个</div></div></div>${miniChartSVG}</div><div class="card"><div class="card-title">全寿命事件时间线 (共 ${localEvents.length} 条)</div><div class="timeline">${localEvents.map(t => `<div class="tl-item"><div class="tl-date">${t.date}</div><div class="tl-title">${t.type}</div><div class="tl-desc">${t.desc}</div></div>`).join('')}</div></div>`; }

function updateAIDropdown() { const sel = document.getElementById('ai-target'); const codes = [...new Set(userDB.events.map(e => e.code))]; const validCodes = codes.filter(c => extractThicknessData(c).length >= 2); sel.innerHTML = validCodes.length > 0 ? validCodes.map(c => `<option value="${c}">${c} (${extractThicknessData(c).length}个测厚点)</option>`).join('') : '<option value="">-- 暂无具备2个以上测厚点的管码，请先录入数据 --</option>'; }
function runAIAnalysis() { const target = document.getElementById('ai-target').value; const threshold = parseFloat(document.getElementById('ai-threshold').value); if(!target) { alert('请先录入至少2次测厚数据'); return; } document.getElementById('ai-loading').style.display = 'block'; document.getElementById('ai-results').style.display = 'none'; setTimeout(() => { const history = extractThicknessData(target); const reg = linearRegression(history); if (!reg) { alert('数据不足或无法计算回归线'); document.getElementById('ai-loading').style.display = 'none'; return; } const rate = -reg.m; const currentYear = history[history.length-1].year; const currentVal = history[history.length-1].val; const prediction = []; for(let i=1; i<=5; i++) { const futureYear = currentYear + i; const futureVal = reg.m * futureYear + reg.b; prediction.push({year: futureYear, val: futureVal}); } let rul = 'N/A'; let status = '正常'; let statusColor = 'var(--ok)'; if (reg.m < 0) { const threshYear = (threshold - reg.b) / reg.m; const rulYears = threshYear - currentYear; if (rulYears > 0) { rul = rulYears.toFixed(1); if (rulYears < 2) { status = '预警'; statusColor = 'var(--danger)'; } else if (rulYears < 5) { status = '关注'; statusColor = 'var(--warn)'; } } else { rul = '0 (已超标)'; status = '危险'; statusColor = 'var(--danger)'; } } else { status = '异常(增厚)'; statusColor = 'var(--warn)'; } const aiData = { history, prediction, threshold, rate: rate.toFixed(3), rul, status, statusColor, currentVal, currentYear }; renderAIResults(aiData, target); }, 1500); }
function renderAIResults(data, target) { document.getElementById('ai-loading').style.display = 'none'; document.getElementById('ai-results').style.display = 'block'; document.getElementById('ai-rul').textContent = data.rul; document.getElementById('ai-rate').textContent = data.rate; document.getElementById('ai-points').textContent = data.history.length; document.getElementById('ai-status').textContent = data.status; document.getElementById('ai-status').style.color = data.statusColor; renderAIChart(data); const report = `【AI 线性回归趋势分析报告】\n对象：${target}\n算法：最小二乘法 (Ordinary Least Squares)\n\n1. 数据基础：成功提取 ${data.history.length} 个真实历史测厚数据点。\n2. 趋势计算：拟合直线斜率为 ${(-data.rate).toFixed(3)} mm/年。当前最新壁厚为 ${data.currentVal} mm。\n3. 寿命预测：按照当前真实减薄速率，预计将在 ${data.rul} 年后触及设定的报废阈值 (${data.threshold} mm)。\n4. AI 建议：${data.status === '预警' || data.status === '危险' ? '减薄速率过快，建议立即安排超声波测厚(UT)复测，并检查烟气侧冲刷情况，必要时提前更换。' : '状态可控，建议按常规检修周期继续监控。'}`; typeWriter('ai-report-text', report, 15); }
function renderAIChart(data) { const svg = document.getElementById('aiChart'); svg.innerHTML = ''; const width = 800, height = 300, padding = { top: 20, right: 50, bottom: 40, left: 60 }; const chartW = width - padding.left - padding.right, chartH = height - padding.top - padding.bottom; const allPoints = [...data.history, ...data.prediction]; const minYear = Math.min(...allPoints.map(p => p.year)) - 0.5; const maxYear = Math.max(...allPoints.map(p => p.year)) + 0.5; const minVal = Math.min(data.threshold, ...allPoints.map(p => p.val)) * 0.95; const maxVal = Math.max(...allPoints.map(p => p.val)) * 1.05; const xScale = (year) => padding.left + ((year - minYear) / (maxYear - minYear)) * chartW; const yScale = (val) => padding.top + chartH - ((val - minVal) / (maxVal - minVal)) * chartH; for(let i=0; i<=5; i++) { const y = padding.top + (chartH / 5) * i, val = maxVal - ((maxVal - minVal) / 5) * i; svg.innerHTML += `<line x1="${padding.left}" y1="${y}" x2="${width-padding.right}" y2="${y}" stroke="rgba(0,212,255,0.1)" stroke-width="1" /><text x="${padding.left-10}" y="${y+4}" fill="#7fb3d5" font-size="10" text-anchor="end">${val.toFixed(1)}</text>`; } for(let y = Math.ceil(minYear); y <= Math.floor(maxYear); y++) svg.innerHTML += `<text x="${xScale(y)}" y="${height - 10}" fill="#7fb3d5" font-size="10" text-anchor="middle">${y}</text>`; const threshY = yScale(data.threshold); svg.innerHTML += `<line x1="${padding.left}" y1="${threshY}" x2="${width-padding.right}" y2="${threshY}" stroke="#ff3860" stroke-width="2" stroke-dasharray="6,4" /><text x="${width-padding.right+5}" y="${threshY+4}" fill="#ff3860" font-size="11" font-weight="bold">阈值 ${data.threshold}</text>`; let histPath = data.history.map((p, i) => `${i===0?'M':'L'} ${xScale(p.year)} ${yScale(p.val)}`).join(' '); svg.innerHTML += `<path d="${histPath}" fill="none" stroke="#00d4ff" stroke-width="3" filter="drop-shadow(0 0 4px #00d4ff)" />`; data.history.forEach(p => svg.innerHTML += `<circle cx="${xScale(p.year)}" cy="${yScale(p.val)}" r="5" fill="#001122" stroke="#00d4ff" stroke-width="2" />`); const lastHist = data.history[data.history.length - 1]; let predPath = `M ${xScale(lastHist.year)} ${yScale(lastHist.val)} ` + data.prediction.map(p => `L ${xScale(p.year)} ${yScale(p.val)}`).join(' '); svg.innerHTML += `<path d="${predPath}" fill="none" stroke="#00e676" stroke-width="3" stroke-dasharray="8,6" filter="drop-shadow(0 0 4px #00e676)" />`; data.prediction.forEach(p => svg.innerHTML += `<circle cx="${xScale(p.year)}" cy="${yScale(p.val)}" r="4" fill="#00e676" />`); }
function typeWriter(elementId, text, speed = 20) { const el = document.getElementById(elementId); el.innerHTML = ''; let i = 0; const cursor = '<span class="ai-cursor"></span>'; function type() { if (i < text.length) { el.innerHTML = text.substring(0, i + 1).replace(/\n/g, '<br>') + cursor; i++; setTimeout(type, speed); } else { el.innerHTML = text.replace(/\n/g, '<br>'); } } type(); }

function renderMatrix() { const tbody = document.getElementById('matrixBody'); let total = 0; tbody.innerHTML = matrix.map(m => { const count = (m.pMax - m.pMin + 1) * (m.tMax - m.tMin + 1); total += count; return `<tr><td style="font-family:inherit">${m.name}</td><td><span class="badge ${m.badge}">${m.sys}</span></td><td>${m.zone}</td><td>${m.pMin}~${m.pMax}</td><td>${m.tMin}~${m.tMax}</td><td style="color:var(--accent)">${count}</td><td>${m.spec}</td><td style="font-family:inherit;font-size:11px">${m.mat}</td></tr>`; }).join(''); document.getElementById('invTotal').textContent = total.toLocaleString(); }
function pad(n, len) { return String(n).padStart(len, '0'); }
function generateCSV(boilerId) { const logBox = document.getElementById('invLogBox'); const progBar = document.getElementById('invProgBar'); const progFill = document.getElementById('invProgFill'); const previewBox = document.getElementById('invPreview'); logBox.style.display = 'block'; progBar.style.display = 'block'; logBox.innerHTML = ''; progFill.style.width = '0%'; const boilers = boilerId === 0 ? [1, 2] : [boilerId]; let csvContent = "\uFEFF炉号,系统代码,位置区域,屏/排编号,管圈/管编号,分段特征,完整管码,部件名称,规格,材质\n"; let rowCount = 0; let previewLines = []; invLog(`[INIT] 启动生成引擎... 目标: ${boilers.join(', ')}`); let bIdx = 0, mIdx = 0, p = 0, t = 0; function processChunk() { const startTime = performance.now(); while (performance.now() - startTime < 50 && bIdx < boilers.length) { const b = boilers[bIdx]; const m = matrix[mIdx]; for (; p <= m.pMax; p++) { if (p < m.pMin) p = m.pMin; for (; t <= m.tMax; t++) { if (t < m.tMin) t = m.tMin; const code = `${b}-${m.sys}-${m.zone}-${pad(p,3)}-${pad(t,4)}-000`; csvContent += `${b},${m.sys},${m.zone},${pad(p,3)},${pad(t,4)},000,${code},${m.name},${m.spec},${m.mat}\n`; rowCount++; if (rowCount <= 10) previewLines.push(`<span>${code}</span> | ${m.name}`); } t = m.tMin; } invLog(`[OK] ${b}号炉 - ${m.name} 完毕`); mIdx++; p = 0; t = 0; if (mIdx >= matrix.length) { mIdx = 0; bIdx++; } progFill.style.width = `${((bIdx * matrix.length + mIdx) / (boilers.length * matrix.length)) * 100}%`; } if (bIdx < boilers.length) { requestAnimationFrame(processChunk); } else { progFill.style.width = '100%'; invLog(`[DONE] 总计 ${rowCount.toLocaleString()} 条。正在打包...`); previewBox.innerHTML = previewLines.join('<br>') + '<br><span>... (共 ' + rowCount.toLocaleString() + ' 条)</span>'; const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' }); const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = `锅炉管段台账_${boilerId===0?'全厂':boilerId+'号炉'}_${new Date().toISOString().slice(0,10)}.csv`; a.click(); URL.revokeObjectURL(a.href); } } requestAnimationFrame(processChunk); }
function invLog(msg) { const logBox = document.getElementById('invLogBox'); logBox.innerHTML += `<div>[${new Date().toLocaleTimeString('zh-CN', {hour12:false})}] ${msg}</div>`; logBox.scrollTop = logBox.scrollHeight; }

