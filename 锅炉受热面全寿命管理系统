</header>

<nav>
  <button class="nav-btn active" data-view="dashboard">◈ 总览</button>
  <button class="nav-btn" data-view="generator">⚙ 编码生成</button>
  <button class="nav-btn" data-view="search">🔍 精准查询</button>
  <button class="nav-btn" data-view="components">▣ 受热面库</button>
  <button class="nav-btn" data-view="headers">⬢ 集箱库</button>
  <button class="nav-btn" data-view="lifecycle">⏳ 寿命跟踪</button>
  <button class="nav-btn" data-view="datamgr">📝 数据录入</button>
