function extractThicknessData(code) { const events = userDB.events.filter(e => e.code === code && (e.type.includes('测厚') || e.desc.includes('壁厚'))); const data = []; events.forEach(e => { const match = e.desc.match(/(?:壁厚|减薄至|厚度)\s*[:：]?\s*(\d+\.?\d*)/i); if (match) { const d = new Date(e.date); const year = d.getFullYear() + (d.getMonth() / 12); data.push({ year: parseFloat(year.toFixed(2)), val: parseFloat(match[1]), dateStr: e.date }); } }); return data.sort((a, b) => a.year - b.year); }
function linearRegression(points) { const n = points.length; if (n < 2) return null; let sumX = 0, sumY = 0, sumXY = 0, sumXX = 0; points.forEach(p => { sumX += p.year; sumY += p.val; sumXY += p.year * p.val; sumXX += p.year * p.year; }); const denominator = (n * sumXX - sumX * sumX); if (denominator === 0) return null; const m = (n * sumXY - sumX * sumY) / denominator; const b = (sumY - m * sumX) / n; return { m, b }; }

