function importCSV(event) { const file = event.target.files[0]; if (!file) return; const reader = new FileReader(); reader.onload = function(e) { try { const text = e.target.result; const lines = text.split(/\r?\n/).filter(line => line.trim() !== ''); if (lines.length < 2) { alert('CSV文件为空'); return; } function parseCSVLine(line) { const result = []; let current = ''; let inQuotes = false; for (let i = 0; i < line.length; i++) { const char = line[i]; if (char === '"') { if (inQuotes && line[i+1] === '"') { current += '"'; i++; } else { inQuotes = !inQuotes; } } else if (char === ',' && !inQuotes) { result.push(current); current = ''; } else { current += char; } } result.push(current); return result; } let importEvents = 0, importReplacements = 0; for (let i = 1; i < lines.length; i++) { const cols = parseCSVLine(lines[i]); if (cols.length < 5) continue; const category = cols[0].trim(); const date = cols[1].trim(); const code = cols[2].trim().toUpperCase(); const typeOrReason = cols[3].trim(); const relatedCode = cols[4].trim().toUpperCase(); const desc = cols[5] ? cols[5].trim() : ''; const ts = Date.now() + i; if (category === '事件' || category === 'event') { userDB.events.push({ code, type: typeOrReason, date, desc, ts }); importEvents++; } else if (category === '更换' || category === 'replacement') { userDB.replacements.push({ oldCode: code, newCode: relatedCode, reason: typeOrReason, date, ts }); userDB.events.push({ code: code, type: '报废更换', date, desc: `更换为新管 ${relatedCode}，原因：${typeOrReason}`, ts: ts + 0.1 }); userDB.events.push({ code: relatedCode, type: '安装投运', date, desc: `替换旧管 ${code}，继承历史数据`, ts: ts + 0.2 }); importReplacements++; } } saveDB(); alert(`✅ 导入成功！\n新增事件: ${importEvents} 条\n新增更换: ${importReplacements} 条`); } catch (err) { alert('❌ CSV 解析失败'); } }; reader.readAsText(file, 'UTF-8'); event.target.value = ''; }
